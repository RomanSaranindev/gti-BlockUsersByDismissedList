// Модуль формы: гти_БлокировкаУволенныхПользователей / ФормаОбработки

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗагрузитьНастройкиСервер();
	
	Заголовок = "Блокировка уволенных пользователей";
	
КонецПроцедуры // ПриСозданииНаСервере()

#КонецОбласти // ОбработчикиСобытийФормы


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьСписок(Команда)
	
	Если ПустаяСтрока(Объект.КаталогВыгрузки) Тогда
		ПоказатьПредупреждение(, "Не указан каталог выгрузки. Перейдите на вкладку «Настройки» и укажите каталог.");
		Возврат;
	КонецЕсли;
	
	// В клиент-серверном режиме НайтиФайлы() на сервере видит файловую систему
	// сервера, а не клиента. Поэтому находим и читаем файл на клиенте,
	// затем передаём содержимое на сервер через временное хранилище.
	
	Состояние("Поиск файла выгрузки...");
	
	// Найти последний .txt в каталоге — на клиенте
	ПутьКФайлу = НайтиПоследнийФайлКлиент(Объект.КаталогВыгрузки);
	
	Если ПутьКФайлу = "" Тогда
		ПоказатьПредупреждение(, "В каталоге """ + Объект.КаталогВыгрузки
			+ """ не найдено ни одного .txt файла.");
		Возврат;
	КонецЕсли;
	
	Состояние("Чтение файла: " + ПутьКФайлу + "...");
	
	// Читаем файл на клиенте с автоопределением кодировки
	ТекстФайла = ПрочитатьФайлКлиент(ПутьКФайлу);
	
	Если ПустаяСтрока(ТекстФайла) Тогда
		ПоказатьПредупреждение(, "Файл пустой или не удалось прочитать: " + ПутьКФайлу);
		Возврат;
	КонецЕсли;
	
	// Передаём текст файла на сервер через временное хранилище
	АдресВХранилище = ПоместитьВоВременноеХранилище(ТекстФайла, УникальныйИдентификатор);
	
	Состояние("Обработка списка и поиск пользователей...");
	
	КоличествоЗагружено = ЗагрузитьСписокСервер(АдресВХранилище);
	
	Если КоличествоЗагружено = 0 Тогда
		ПоказатьПредупреждение(, "Файл прочитан, но записи о сотрудниках не найдены. Проверьте формат файла.");
	Иначе
		КоличествоНайдено = КоличествоНайденныхСервер();
		ПоказатьОповещениеПользователя(
			"Загрузка завершена",
			,
			"Записей из файла: " + КоличествоЗагружено + Символы.ПС
				+ "Найдено пользователей в базе: " + КоличествоНайдено
		);
	КонецЕсли;
	
КонецПроцедуры // ЗагрузитьСписок()

&НаКлиенте
Процедура ВыполнитьБлокировку(Команда)
	
	КоличествоОтмеченных = КоличествоОтмеченныхСтрок();
	
	Если КоличествоОтмеченных = 0 Тогда
		ПоказатьПредупреждение(, "Нет отмеченных для блокировки пользователей.");
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыполнитьБлокировкуПодтверждение", ЭтотОбъект);
	ПоказатьВопрос(
		ОписаниеОповещения,
		"Будет выполнена блокировка " + КоличествоОтмеченных + " пользователей." + Символы.ПС
			+ "Флаг «Недействителен» будет установлен." + Символы.ПС + Символы.ПС
			+ "Продолжить?",
		РежимДиалогаВопрос.ДаНет,
		,
		КодВозвратаДиалога.Да
	);
	
КонецПроцедуры // ВыполнитьБлокировку()

&НаКлиенте
Процедура ВыполнитьБлокировкуПодтверждение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Состояние("Выполняется блокировка пользователей...");
	
	Результат = ВыполнитьБлокировкуСервер();
	
	ПоказатьОповещениеПользователя(
		"Блокировка завершена",
		,
		"Заблокировано: "        + Результат.Заблокировано   + Символы.ПС
			+ "Пропущено (переводы): " + Результат.Пропущено      + Символы.ПС
			+ "Ошибок: "               + Результат.Ошибки
	);
	
КонецПроцедуры // ВыполнитьБлокировкуПодтверждение()

&НаКлиенте
Процедура СнятьВсеОтметки(Команда)
	УстановитьОтметкиВсем(Ложь);
КонецПроцедуры // СнятьВсеОтметки()

&НаКлиенте
Процедура ПоставитьВсеОтметки(Команда)
	УстановитьОтметкиВсем(Истина);
КонецПроцедуры // ПоставитьВсеОтметки()

&НаКлиенте
Процедура ВыбратьКаталог(Команда)
	
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	ДиалогВыбора.Заголовок = "Выберите каталог с файлами выгрузки уволенных";
	Если НЕ ПустаяСтрока(Объект.КаталогВыгрузки) Тогда
		ДиалогВыбора.Каталог = Объект.КаталогВыгрузки;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("КаталогВыбран", ЭтотОбъект);
	ДиалогВыбора.Показать(ОписаниеОповещения);
	
КонецПроцедуры // ВыбратьКаталог()

&НаКлиенте
Процедура КаталогВыбран(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Объект.КаталогВыгрузки = ВыбранныеФайлы[0];
	
КонецПроцедуры // КаталогВыбран()

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	Для Каждого Стр Из Объект.СписокАдминистраторов Цикл
		Если НЕ ЗначениеЗаполнено(Стр.Пользователь) Тогда
			ПоказатьПредупреждение(, "В списке администраторов есть незаполненные строки.");
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	СохранитьНастройкиСервер();
	ПоказатьОповещениеПользователя("Настройки сохранены", , "Настройки успешно сохранены.");
	
КонецПроцедуры // СохранитьНастройки()

#КонецОбласти // ОбработчикиКомандФормы


#Область СлужебныеКлиентскиеПроцедуры

// Находит последний .txt файл в каталоге НА КЛИЕНТЕ.
// Возвращает полный путь к файлу или пустую строку.
&НаКлиенте
Функция НайтиПоследнийФайлКлиент(КаталогФайлов)
	
	КаталогФайлов = СокрЛП(КаталогФайлов);
	
	// Добавить разделитель в конце если нет
	Если НЕ (Прав(КаталогФайлов, 1) = "\" ИЛИ Прав(КаталогФайлов, 1) = "/") Тогда
		КаталогФайлов = КаталогФайлов + "\";
	КонецЕсли;
	
	// Проверить существование каталога
	ОбъектКаталог = Новый Файл(КаталогФайлов);
	Если НЕ ОбъектКаталог.Существует() Тогда
		Возврат "";
	КонецЕсли;
	
	// Найти все .txt файлы
	ФайлыВКаталоге = НайтиФайлы(КаталогФайлов, "*.txt", Ложь);
	
	Если ФайлыВКаталоге.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	// Выбрать самый свежий по дате изменения
	ПоследнийФайл = ФайлыВКаталоге[0];
	Для Каждого Файл Из ФайлыВКаталоге Цикл
		Если Файл.ПолучитьВремяИзменения() > ПоследнийФайл.ПолучитьВремяИзменения() Тогда
			ПоследнийФайл = Файл;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПоследнийФайл.ПолноеИмя;
	
КонецФункции // НайтиПоследнийФайлКлиент()

// Читает текстовый файл НА КЛИЕНТЕ с автоопределением кодировки.
// Outlook сохраняет .txt в CP1251 без BOM.
&НаКлиенте
Функция ПрочитатьФайлКлиент(ПутьКФайлу)
	
	// Попытка 1: UTF-8
	Попытка
		ЧтениеUTF = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
		ТекстUTF  = ЧтениеUTF.Прочитать();
		ЧтениеUTF.Закрыть();
		Если СтрНайти(ТекстUTF, "ФИО:") > 0
			ИЛИ СтрНайти(ТекстUTF, "Уволен") > 0
			ИЛИ СтрНайти(ТекстUTF, "Должность:") > 0 Тогда
			Возврат ТекстUTF;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	// Попытка 2: CP1251 — стандартная кодировка Outlook .txt
	Попытка
		ЧтениеANSI = Новый ЧтениеТекста(ПутьКФайлу, "windows-1251");
		ТекстANSI  = ЧтениеANSI.Прочитать();
		ЧтениеANSI.Закрыть();
		Если СтрНайти(ТекстANSI, "ФИО:") > 0
			ИЛИ СтрНайти(ТекстANSI, "Уволен") > 0
			ИЛИ СтрНайти(ТекстANSI, "Должность:") > 0 Тогда
			Возврат ТекстANSI;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	// Попытка 3: системная кодировка
	Попытка
		ЧтениеСист = Новый ЧтениеТекста(ПутьКФайлу);
		ТекстСист  = ЧтениеСист.Прочитать();
		ЧтениеСист.Закрыть();
		Возврат ТекстСист;
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции // ПрочитатьФайлКлиент()

&НаКлиенте
Функция КоличествоОтмеченныхСтрок()
	Количество = 0;
	Для Каждого Стр Из Объект.НайденныеСотрудники Цикл
		Если Стр.Заблокировать И Стр.НайденВБазе Тогда
			Количество = Количество + 1;
		КонецЕсли;
	КонецЦикла;
	Возврат Количество;
КонецФункции // КоличествоОтмеченныхСтрок()

&НаКлиенте
Процедура УстановитьОтметкиВсем(Значение)
	Для Каждого Стр Из Объект.НайденныеСотрудники Цикл
		Если Стр.НайденВБазе И НЕ Стр.ПометкаПеревода Тогда
			Стр.Заблокировать = Значение;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры // УстановитьОтметкиВсем()

#КонецОбласти // СлужебныеКлиентскиеПроцедуры


#Область СлужебныеСерверныеПроцедуры

// ────────────────────────────────────────────────
// Настройки
// ────────────────────────────────────────────────

&НаСервере
Процедура ЗагрузитьНастройкиСервер()
	
	Настройки = ХранилищеОбщихНастроек.Загрузить(
		"гти_БлокировкаУволенныхПользователей", "НастройкиОбработки");
	
	Если ТипЗнч(Настройки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Настройки.Свойство("КаталогВыгрузки") Тогда
		Объект.КаталогВыгрузки = Настройки.КаталогВыгрузки;
	КонецЕсли;
	
	Если Настройки.Свойство("СписокАдминистраторов")
		И ТипЗнч(Настройки.СписокАдминистраторов) = Тип("ТаблицаЗначений") Тогда
		Объект.СписокАдминистраторов.Загрузить(Настройки.СписокАдминистраторов);
	КонецЕсли;
	
КонецПроцедуры // ЗагрузитьНастройкиСервер()

&НаСервере
Процедура СохранитьНастройкиСервер()
	
	Настройки = Новый Структура;
	Настройки.Вставить("КаталогВыгрузки",        Объект.КаталогВыгрузки);
	Настройки.Вставить("СписокАдминистраторов",   Объект.СписокАдминистраторов.Выгрузить());
	
	ХранилищеОбщихНастроек.Сохранить(
		"гти_БлокировкаУволенныхПользователей", "НастройкиОбработки", Настройки);
	
КонецПроцедуры // СохранитьНастройкиСервер()

// ────────────────────────────────────────────────
// Загрузка списка
// ────────────────────────────────────────────────

// АдресВХранилище — адрес строки с текстом файла, переданной клиентом
&НаСервере
Функция ЗагрузитьСписокСервер(АдресВХранилище)
	
	Объект.НайденныеСотрудники.Очистить();
	
	// Получаем текст из временного хранилища (передан клиентом)
	ТекстФайла = ПолучитьИзВременногоХранилища(АдресВХранилище);
	
	Если ТипЗнч(ТекстФайла) <> Тип("Строка") ИЛИ ПустаяСтрока(ТекстФайла) Тогда
		Возврат 0;
	КонецЕсли;
	
	МассивСотрудников = РазобратьТекстВыгрузки(ТекстФайла);
	Если МассивСотрудников.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	ЗаполнитьТаблицуСотрудников(МассивСотрудников);
	
	Возврат Объект.НайденныеСотрудники.Количество();
	
КонецФункции // ЗагрузитьСписокСервер()

&НаСервере
Функция КоличествоНайденныхСервер()
	Количество = 0;
	Для Каждого Стр Из Объект.НайденныеСотрудники Цикл
		Если Стр.НайденВБазе Тогда Количество = Количество + 1; КонецЕсли;
	КонецЦикла;
	Возврат Количество;
КонецФункции // КоличествоНайденныхСервер()

// ────────────────────────────────────────────────
// Блокировка
// ────────────────────────────────────────────────

&НаСервере
Функция ВыполнитьБлокировкуСервер()
	
	Результат = Новый Структура("Заблокировано, Пропущено, Ошибки, ТекстЛога", 0, 0, 0, "");
	
	// Определить имя текущего администратора
	ИмяАдминистратора = ОпределитьИмяАдминистратора();
	
	СтрокиЛога = Новый Массив;
	СтрокиЛога.Добавить("<h2>Отчёт о блокировке пользователей 1С</h2>");
	СтрокиЛога.Добавить("<p><b>Дата обработки:</b> " + Формат(ТекущаяДата(), "ДЛФ=ДВ") + "</p>");
	СтрокиЛога.Добавить("<p><b>Выполнил:</b> " + ИмяАдминистратора + "</p><hr/>");
	СтрокиЛога.Добавить("<table border='1' cellpadding='4' cellspacing='0' style='border-collapse:collapse;font-family:Arial;font-size:12px;'>");
	СтрокиЛога.Добавить("<tr style='background:#336699;color:white;'><th>ФИО</th><th>Пользователь 1С</th><th>Организация</th><th>Должность</th><th>Дата увольнения</th><th>Визы</th><th>Роли</th><th>Переведён</th><th>Орг. перевода</th><th>Статус</th></tr>");
	
	Для Каждого Строка Из Объект.НайденныеСотрудники Цикл
		
		Если НЕ Строка.Заблокировать Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ Строка.НайденВБазе Тогда
			Строка.Статус = "Не найден в базе";
			ДобавитьСтрокуВЛог(СтрокиЛога, Строка, "grey", "Не найден в базе 1С");
			Результат.Ошибки = Результат.Ошибки + 1;
			Продолжить;
		КонецЕсли;
		
		Если Строка.ПометкаПеревода Тогда
			// Только комментарий, без блокировки
			ЗаписатьКомментарийПользователю(Строка.Пользователь, ИмяАдминистратора, Строка.ДатаУвольнения, Истина);
			Строка.Статус = "Переведён — доступ сохранён, комментарий записан";
			ДобавитьСтрокуВЛог(СтрокиЛога, Строка, "#FFF3CD", "⚠ Переведён в другую организацию");
			Результат.Пропущено = Результат.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		ЕстьВизыИлиРоли = НЕ ПустаяСтрока(Строка.СписокВиз)
			Или НЕ ПустаяСтрока(Строка.СписокРолей);
		
		Попытка
			ПользовательОбъект = Строка.Пользователь.ПолучитьОбъект();
			
			// Полная блокировка во всех случаях
			ПользовательОбъект.Недействителен = Истина;
			
			Если ЕстьВизыИлиРоли Тогда
				// Есть визы/роли — блокируем полностью, но в логе отмечаем особо
				// чтобы администраторы проверили вручную
				ЗаписатьКомментарийПользователю(ПользовательОбъект, ИмяАдминистратора, Строка.ДатаУвольнения, Ложь, Истина);
				ПользовательОбъект.Записать();
				ЗапретитьВходВИБ(ПользовательОбъект);
				Строка.Статус = "Заблокирован (! есть визы/роли)";
				ДобавитьСтрокуВЛог(СтрокиЛога, Строка, "#FFE0B2",
					"Заблокирован — имеются визы/роли, требуется ручная проверка");
			Иначе
				// Нет виз и ролей — стандартная полная блокировка
				ЗаписатьКомментарийПользователю(ПользовательОбъект, ИмяАдминистратора, Строка.ДатаУвольнения, Ложь);
				ПользовательОбъект.Записать();
				ЗапретитьВходВИБ(ПользовательОбъект);
				Строка.Статус = "Заблокирован";
				ДобавитьСтрокуВЛог(СтрокиЛога, Строка, "#D4EDDA", "Заблокирован");
			КонецЕсли;
			Результат.Заблокировано = Результат.Заблокировано + 1;
			
		Исключение
			Строка.Статус = "Ошибка: " + ОписаниеОшибки();
			ДобавитьСтрокуВЛог(СтрокиЛога, Строка, "#F8D7DA", Строка.Статус);
			Результат.Ошибки = Результат.Ошибки + 1;
		КонецПопытки;
		
	КонецЦикла;
	
	СтрокиЛога.Добавить("</table><br/><p><b>Итого:</b> заблокировано: <b>"
		+ Результат.Заблокировано + "</b>, пропущено (перевод): <b>"
		+ Результат.Пропущено + "</b>, ошибок: <b>" + Результат.Ошибки + "</b></p>");
	
	Результат.ТекстЛога = СтрСоединить(СтрокиЛога, "");
	
	// Отправить лог администраторам
	Если НЕ ПустаяСтрока(Результат.ТекстЛога) Тогда
		ОтправитьЛогАдминистраторам(Результат.ТекстЛога,
			"Блокировка пользователей 1С — " + Формат(ТекущаяДата(), "ДЛФ=Д"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ВыполнитьБлокировкуСервер()

// ────────────────────────────────────────────────
// Парсер файла
// ────────────────────────────────────────────────

// Разбирает текст файла выгрузки в массив структур сотрудников.
// Текст уже прочитан на клиенте и передан через временное хранилище.
&НаСервере
Функция РазобратьТекстВыгрузки(ТекстФайла)
	
	МассивСотрудников = Новый Массив;
	
	// Истина — сохранять пустые строки, они служат разделителями блоков сотрудников
	МассивСтрок = СтрРазделить(ТекстФайла, Символы.ПС, Истина);
	
	ТекущийСотрудник = Неопределено;
	РежимДругихМест  = Ложь;
	ДругиеМестаРаботы = "";
	
	Для Каждого СтрокаТекста Из МассивСтрок Цикл
		
		СтрокаТекста = СокрЛП(СтрЗаменить(СтрокаТекста, Символы.ВК, ""));
		
		Если ПустаяСтрока(СтрокаТекста) Тогда
			Если ТекущийСотрудник <> Неопределено Тогда
				ТекущийСотрудник.ДругиеМестаРаботы = СокрЛП(ДругиеМестаРаботы);
				// ЕстьПеревод мог быть уже выставлен через "Причина увольнения: Перевод"
				ТекущийСотрудник.ЕстьПеревод = ТекущийСотрудник.ЕстьПеревод
					ИЛИ НЕ ПустаяСтрока(СокрЛП(ДругиеМестаРаботы));
				МассивСотрудников.Добавить(ТекущийСотрудник);
				ТекущийСотрудник  = Неопределено;
				РежимДругихМест   = Ложь;
				ДругиеМестаРаботы = "";
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Пропускаем заголовки письма Outlook и служебные строки
		Если СтрНачинаетсяС(СтрокаТекста, "Уволенные сотрудники от:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "От:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Отправлено:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Кому:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Тема:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Копия:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "From:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "To:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Sent:")
			ИЛИ СтрНачинаетсяС(СтрокаТекста, "Subject:") Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СтрокаТекста, "ФИО:") Тогда
			ТекущийСотрудник = Новый Структура(
				"ФИО, Должность, Отдел, Организация, ДатаПриема, ДатаУвольнения, ВидТрудоустройства, ДругиеМестаРаботы, ЕстьПеревод",
				"", "", "", "", '00010101', '00010101', "", "", Ложь);
			РежимДругихМест   = Ложь;
			ДругиеМестаРаботы = "";
			ТекущийСотрудник.ФИО = ИзвлечьЗначениеПоля(СтрокаТекста, "ФИО:");
			Продолжить;
		КонецЕсли;
		
		Если ТекущийСотрудник = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СтрокаТекста, "Должность:") Тогда
			ТекущийСотрудник.Должность = ИзвлечьЗначениеПоля(СтрокаТекста, "Должность:");
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Отдел:") Тогда
			ТекущийСотрудник.Отдел = ИзвлечьЗначениеПоля(СтрокаТекста, "Отдел:");
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Организация:") Тогда
			ТекущийСотрудник.Организация = ИзвлечьЗначениеПоля(СтрокаТекста, "Организация:");
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Дата приема:") Тогда
			ТекущийСотрудник.ДатаПриема = РазобратьДатуИзФайла(ИзвлечьЗначениеПоля(СтрокаТекста, "Дата приема:"));
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Дата увольнения:") Тогда
			ТекущийСотрудник.ДатаУвольнения = РазобратьДатуИзФайла(ИзвлечьЗначениеПоля(СтрокаТекста, "Дата увольнения:"));
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Вид трудоустройства:") Тогда
			ТекущийСотрудник.ВидТрудоустройства = ИзвлечьЗначениеПоля(СтрокаТекста, "Вид трудоустройства:");
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Причина увольнения:") Тогда
			// Формат 2: признак перевода через поле "Причина увольнения: Перевод"
			ПричинаУвольнения = ВРег(СокрЛП(ИзвлечьЗначениеПоля(СтрокаТекста, "Причина увольнения:")));
			Если ПричинаУвольнения = "ПЕРЕВОД" Тогда
				ТекущийСотрудник.ЕстьПеревод = Истина;
			КонецЕсли;
			РежимДругихМест = Ложь;
		ИначеЕсли СтрНачинаетсяС(СтрокаТекста, "Другие места работы:") Тогда
			РежимДругихМест = Истина;
			ЗначениеПосле = ИзвлечьЗначениеПоля(СтрокаТекста, "Другие места работы:");
			Если НЕ ПустаяСтрока(ЗначениеПосле) Тогда
				ДругиеМестаРаботы = ЗначениеПосле;
			КонецЕсли;
		ИначеЕсли РежимДругихМест Тогда
			Если НЕ ПустаяСтрока(ДругиеМестаРаботы) Тогда
				ДругиеМестаРаботы = ДругиеМестаРаботы + "; ";
			КонецЕсли;
			ДругиеМестаРаботы = ДругиеМестаРаботы + СтрокаТекста;
		КонецЕсли;
		
	КонецЦикла;
	
	// Последний сотрудник без финальной пустой строки
	Если ТекущийСотрудник <> Неопределено Тогда
		ТекущийСотрудник.ДругиеМестаРаботы = СокрЛП(ДругиеМестаРаботы);
		ТекущийСотрудник.ЕстьПеревод = ТекущийСотрудник.ЕстьПеревод
			ИЛИ НЕ ПустаяСтрока(СокрЛП(ДругиеМестаРаботы));
		МассивСотрудников.Добавить(ТекущийСотрудник);
	КонецЕсли;
	
	Возврат МассивСотрудников;
	
КонецФункции // РазобратьТекстВыгрузки()

&НаСервере
Процедура ЗаполнитьТаблицуСотрудников(МассивСотрудников)
	
	ТаблицаПользователей = ПолучитьТаблицуПользователей();
	
	Для Каждого СтрСотр Из МассивСотрудников Цикл
		
		НовСтр = Объект.НайденныеСотрудники.Добавить();
		НовСтр.ФИОИзФайла       = СтрСотр.ФИО;
		НовСтр.Должность         = СтрСотр.Должность;
		НовСтр.Организация       = СтрСотр.Организация;
		НовСтр.ОрганизацияВБазе  = НайтиОрганизациюПоНаименованиюИзФайла(СтрСотр.Организация);
		
		// Организация после перевода — извлекаем из «Другие места работы»
		Если НЕ ПустаяСтрока(СтрСотр.ДругиеМестаРаботы) Тогда
			ОргПеревода = ИзвлечьОрганизациюИзДругихМестРаботы(СтрСотр.ДругиеМестаРаботы);
			Если НЕ ПустаяСтрока(ОргПеревода) Тогда
				НовСтр.ОрганизацияПослеПеревода = НайтиОрганизациюПоНаименованиюИзФайла(ОргПеревода);
			КонецЕсли;
		КонецЕсли;
		НовСтр.ДатаПриема        = СтрСотр.ДатаПриема;
		НовСтр.ДатаУвольнения    = СтрСотр.ДатаУвольнения;
		НовСтр.ПометкаПеревода   = СтрСотр.ЕстьПеревод;
		НовСтр.ДругиеМестаРаботы = СтрСотр.ДругиеМестаРаботы;
		НовСтр.НайденВБазе       = Ложь;
		НовСтр.Заблокировать     = Ложь;
		
		ФИООчищенное = ОчиститьФИООтПостфиксов(СтрСотр.ФИО);
		НайденПользователь = НайтиПользователяПоФИО(ФИООчищенное, ТаблицаПользователей);
		
		Если НайденПользователь <> Неопределено Тогда
			НовСтр.Пользователь  = НайденПользователь.Ссылка;
			НовСтр.НайденВБазе   = Истина;
			НовСтр.Заблокировать = НЕ НайденПользователь.Недействителен;
			НовСтр.СписокВиз     = ПолучитьСписокВиз(НайденПользователь.Ссылка);
			НовСтр.СписокРолей   = ПолучитьСписокРолей(НайденПользователь.ИдентификаторПользователяИБ);
			НовСтр.Статус        = ?(НайденПользователь.Недействителен, "Уже заблокирован", "Найден");
		Иначе
			НовСтр.Статус = "Не найден в базе";
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // ЗаполнитьТаблицуСотрудников()

// ────────────────────────────────────────────────
// Поиск пользователей
// ────────────────────────────────────────────────

&НаСервере
Функция ПолучитьТаблицуПользователей()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Пользователи.Ссылка                                     КАК Ссылка,
		|	Пользователи.Наименование                               КАК ПолноеИмя,
		|	Пользователи.ФизическоеЛицо                             КАК ФизическоеЛицо,
		|	ЕСТЬNULL(Пользователи.ФизическоеЛицо.Наименование, """") КАК ФИОФизлица,
		|	Пользователи.Недействителен                             КАК Недействителен,
		|	Пользователи.ИдентификаторПользователяИБ                КАК ИдентификаторПользователяИБ
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	НЕ Пользователи.ПометкаУдаления";
	
	ТаблицаПользователей = Запрос.Выполнить().Выгрузить();
	ТаблицаПользователей.Колонки.Добавить("ФИООчищенное", Новый ОписаниеТипов("Строка"));
	
	Для Каждого Стр Из ТаблицаПользователей Цикл
		Стр.ФИООчищенное = ВРег(ОчиститьФИООтПостфиксов(Стр.ПолноеИмя));
	КонецЦикла;
	
	Возврат ТаблицаПользователей;
	
КонецФункции // ПолучитьТаблицуПользователей()

&НаСервере
Функция НайтиПользователяПоФИО(ФИООчищенное, ТаблицаПользователей)
	
	ФИОВерхний = ВРег(СокрЛП(ФИООчищенное));
	Если ПустаяСтрока(ФИОВерхний) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Приоритет 1: по физлицу
	Для Каждого Стр Из ТаблицаПользователей Цикл
		Если НЕ ПустаяСтрока(Стр.ФИОФизлица) Тогда
			Если ВРег(ОчиститьФИООтПостфиксов(Стр.ФИОФизлица)) = ФИОВерхний Тогда
				Возврат Стр;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Приоритет 2: по наименованию пользователя
	Для Каждого Стр Из ТаблицаПользователей Цикл
		Если Стр.ФИООчищенное = ФИОВерхний Тогда
			Возврат Стр;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции // НайтиПользователяПоФИО()

// Ищет организацию в Справочнике.Организации по краткому наименованию, извлечённому из кавычек.
// Например, из строки 'Общество с ограниченной ответственностью "ГЕОТЕХ ИННОВЭЙШН"'
// извлекается 'ГЕОТЕХ ИННОВЭЙШН' и ищется в базе как подстрока наименования.
// Возвращает ссылку или пустую ссылку, если не найдено.
&НаСервере
Функция НайтиОрганизациюПоНаименованиюИзФайла(НаименованиеИзФайла)
	
	Если ПустаяСтрока(НаименованиеИзФайла) Тогда
		Возврат Справочники.Организации.ПустаяСсылка();
	КонецЕсли;
	
	// Ищем текст в кавычках (прямых " или типографских « »)
	// Пробуем прямые кавычки сначала
	КраткоеНаименование = ИзвлечьТекстВКавычках(НаименованиеИзФайла);
	
	Если ПустаяСтрока(КраткоеНаименование) Тогда
		// Если кавычек нет — ищем по полному наименованию
		КраткоеНаименование = СокрЛП(НаименованиеИзФайла);
	КонецЕсли;
	
	// Ищем по наименованию перебором — избегаем СПЕЦСИМВОЛЫ (не поддерживается в данной версии).
	// Организаций в базе немного, поэтому выгружаем всё и сравниваем в 1С-коде.
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Организации.Ссылка КАК Ссылка,
		|	Организации.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	НЕ Организации.ПометкаУдаления";
	
	ПоискВерхний = ВРег(КраткоеНаименование);
	
	РезЗапроса = Запрос.Выполнить().Выгрузить();
	Для Каждого Стр Из РезЗапроса Цикл
		Если СтрНайти(ВРег(Стр.Наименование), ПоискВерхний) > 0 Тогда
			Возврат Стр.Ссылка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Справочники.Организации.ПустаяСсылка();
	
КонецФункции // НайтиОрганизациюПоНаименованиюИзФайла()

// Извлекает текст между первой парой двойных прямых кавычек "..." из строки.
// Также обрабатывает типографские кавычки «...».
// Возвращает пустую строку, если кавычек нет.
&НаСервере
Функция ИзвлечьТекстВКавычках(Строка)
	
	// Прямые кавычки "..."
	НачалоПрямые = СтрНайти(Строка, """");
	Если НачалоПрямые > 0 Тогда
		КонецПрямые = СтрНайти(Строка, """", НаправлениеПоиска.СНачала, НачалоПрямые + 1);
		Если КонецПрямые > НачалоПрямые Тогда
			Возврат СокрЛП(Сред(Строка, НачалоПрямые + 1, КонецПрямые - НачалоПрямые - 1));
		КонецЕсли;
	КонецЕсли;
	
	// Типографские кавычки «...»
	НачалоТипогр = СтрНайти(Строка, "«");
	Если НачалоТипогр > 0 Тогда
		КонецТипогр = СтрНайти(Строка, "»", НаправлениеПоиска.СНачала, НачалоТипогр + 1);
		Если КонецТипогр > НачалоТипогр Тогда
			// «» — 2 байта каждый в UTF-8, но в 1С строка Юникод, 1 символ
			Возврат СокрЛП(Сред(Строка, НачалоТипогр + 1, КонецТипогр - НачалоТипогр - 1));
		КонецЕсли;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции // ИзвлечьТекстВКавычках()

// Извлекает наименование организации из строки «Другие места работы».
// Формат строки: «ФИО, Должность, Отдел, Организация»
// Организация — всё что идёт после третьей запятой (может содержать запятые внутри).
// Если запятых меньше трёх — возвращает пустую строку.
&НаСервере
Функция ИзвлечьОрганизациюИзДругихМестРаботы(СтрокаДругихМест)
	
	// В поле ДругиеМестаРаботы может быть несколько записей через "; "
	// Берём первую запись (до первого "; ")
	ПозРазделителя = СтрНайти(СтрокаДругихМест, "; ");
	Если ПозРазделителя > 0 Тогда
		ПерваяЗапись = СокрЛП(Лев(СтрокаДругихМест, ПозРазделителя - 1));
	Иначе
		ПерваяЗапись = СокрЛП(СтрокаДругихМест);
	КонецЕсли;
	
	Если ПустаяСтрока(ПерваяЗапись) Тогда
		Возврат "";
	КонецЕсли;
	
	// Разбиваем по запятой, организация — всё начиная с 4-го элемента
	Части = СтрРазделить(ПерваяЗапись, ",", Ложь);
	
	Если Части.Количество() < 4 Тогда
		Возврат "";
	КонецЕсли;
	
	// Организация = элементы с индекса 3 до конца (могут быть запятые внутри)
	МассивОрг = Новый Массив;
	Для Инд = 3 По Части.Количество() - 1 Цикл
		МассивОрг.Добавить(СокрЛП(Части[Инд]));
	КонецЦикла;
	
	Возврат СокрЛП(СтрСоединить(МассивОрг, ", "));
	
КонецФункции // ИзвлечьОрганизациюИзДругихМестРаботы()

// ────────────────────────────────────────────────
// Проверка виз и ролей
// ────────────────────────────────────────────────

// Возвращает строку с перечислением названий виз через ", " или "" если нет.
&НаСервере
Функция ПолучитьСписокВиз(ПользовательСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПВ.Виза.Наименование КАК НаименованиеВизы
		|ИЗ
		|	РегистрСведений.бит_ПраваУстановкиВиз КАК ПВ
		|ГДЕ
		|	ПВ.Пользователь = &Пользователь
		|СГРУППИРОВАТЬ ПО
		|	ПВ.Виза.Наименование
		|УПОРЯДОЧИТЬ ПО
		|	ПВ.Виза.Наименование";
	Запрос.УстановитьПараметр("Пользователь", ПользовательСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	НазванияВиз = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Если НЕ ПустаяСтрока(Выборка.НаименованиеВизы) Тогда
			НазванияВиз.Добавить(Выборка.НаименованиеВизы);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(НазванияВиз, ", ");
	
КонецФункции // ПолучитьСписокВиз()

// Возвращает строку с перечислением названий ролей через ", " или "" если нет.
&НаСервере
Функция ПолучитьСписокРолей(ИдентификаторПользователяИБ)
	
	НулевойUID = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	Если ИдентификаторПользователяИБ = НулевойUID Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
			ИдентификаторПользователяИБ);
		Если ПользовательИБ = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		
		НазванияРолей = Новый Массив;
		Для Каждого Роль Из ПользовательИБ.Роли Цикл
			НазванияРолей.Добавить(Роль.Роль.Имя);
		КонецЦикла;
		
		Возврат СтрСоединить(НазванияРолей, ", ");
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции // ПолучитьСписокРолей()

// ────────────────────────────────────────────────
// Комментарий и синхронизация ИБ
// ────────────────────────────────────────────────

// РежимБлокировки: 
//   0 — полная блокировка (Недействителен = Истина)
//   1 — запрет входа без полной блокировки (есть визы/роли)
//   2 — перевод в другую организацию (только комментарий)
&НаСервере
Процедура ЗаписатьКомментарийПользователю(ПользовательОбъектИлиСсылка, ИмяАдминистратора, ДатаУвольнения, ЭтоПеревод, РежимВизыРоли = Ложь)
	
	ДатаСтрока  = Формат(ДатаУвольнения, "ДФ=dd-MM-yyyy");
	Штамп       = Формат(ТекущаяДата(), "ДЛФ=ДВ");
	
	Если ЭтоПеревод Тогда
		НовыйКомментарий = Штамп + " " + ИмяАдминистратора
			+ " сотрудник переведён в другую организацию, доступ сохранён. Уволен от: " + ДатаСтрока;
	ИначеЕсли РежимВизыРоли Тогда
		НовыйКомментарий = Штамп + " " + ИмяАдминистратора
			+ " вход в программу запрещён, карточка активна (есть визы/роли). Уволен от: " + ДатаСтрока;
	Иначе
		НовыйКомментарий = Штамп + " " + ИмяАдминистратора
			+ " блокировка пользователя выполнена автоматически внешней обработкой Уволен от: " + ДатаСтрока;
	КонецЕсли;
	
	Если ТипЗнч(ПользовательОбъектИлиСсылка) = Тип("CatalogRef.Пользователи") Тогда
		ПользовательОбъект = ПользовательОбъектИлиСсылка.ПолучитьОбъект();
	Иначе
		ПользовательОбъект = ПользовательОбъектИлиСсылка;
	КонецЕсли;
	
	Если ПустаяСтрока(ПользовательОбъект.Комментарий) Тогда
		ПользовательОбъект.Комментарий = НовыйКомментарий;
	Иначе
		ПользовательОбъект.Комментарий = ПользовательОбъект.Комментарий + Символы.ПС + НовыйКомментарий;
	КонецЕсли;
	
	Если ТипЗнч(ПользовательОбъектИлиСсылка) = Тип("CatalogRef.Пользователи") Тогда
		ПользовательОбъект.Записать();
	КонецЕсли;
	
КонецПроцедуры // ЗаписатьКомментарийПользователю()

// Запрещает вход в информационную базу путём сброса всех методов аутентификации.
// Используется как при полной блокировке, так и при частичной (есть визы/роли).
// Флаг «Недействителен» в справочнике Пользователи данная процедура не трогает.
&НаСервере
Процедура ЗапретитьВходВИБ(ПользовательОбъект)
	
	НулевойUID = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	Если ПользовательОбъект.ИдентификаторПользователяИБ = НулевойUID Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
			ПользовательОбъект.ИдентификаторПользователяИБ);
		Если ПользовательИБ = Неопределено Тогда
			Возврат;
		КонецЕсли;
		// Сбрасываем все методы аутентификации — пользователь не сможет войти
		ПользовательИБ.АутентификацияСтандартная = Ложь;
		ПользовательИБ.АутентификацияОС          = Ложь;
		ПользовательИБ.ОткрытыйКлюч              = "";
		ПользовательИБ.Записать();
	Исключение
		ЗаписьЖурналаРегистрации("гти_БлокировкаУволенныхПользователей",
			УровеньЖурналаРегистрации.Предупреждение, , ,
			"Запрет входа в ИБ: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры // ЗапретитьВходВИБ()

// ────────────────────────────────────────────────
// Почта
// ────────────────────────────────────────────────

&НаСервере
Процедура ОтправитьЛогАдминистраторам(ТекстЛога, Тема)
	
	Если Объект.СписокАдминистраторов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	МассивКому = Новый Массив;
	Для Каждого СтрАдм Из Объект.СписокАдминистраторов Цикл
		Адрес = СтрАдм.АдресЭлектроннойПочты;
		Если ПустаяСтрока(Адрес) Тогда
			Адрес = ПолучитьАдресПочтыПользователя(СтрАдм.Пользователь);
		КонецЕсли;
		Если НЕ ПустаяСтрока(Адрес) Тогда
			МассивКому.Добавить(Новый Структура("Адрес, Представление", Адрес, Адрес));
		КонецЕсли;
	КонецЦикла;
	
	Если МассивКому.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ПараметрыОтправки = Новый Структура;
		ПараметрыОтправки.Вставить("Кому",      МассивКому);
		ПараметрыОтправки.Вставить("Тема",      Тема);
		ПараметрыОтправки.Вставить("Тело",      ТекстЛога);
		ПараметрыОтправки.Вставить("ТипТекста", "HTML");
		
		УчетнаяЗапись = РаботаСПочтовымиСообщениями.СистемнаяУчетнаяЗапись();
		РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(УчетнаяЗапись, ПараметрыОтправки);
	Исключение
		ЗаписьЖурналаРегистрации("гти_БлокировкаУволенныхПользователей",
			УровеньЖурналаРегистрации.Предупреждение, , ,
			"Ошибка отправки лога: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры // ОтправитьЛогАдминистраторам()

&НаСервере
Функция ПолучитьАдресПочтыПользователя(ПользовательСсылка)
	
	Если НЕ ЗначениеЗаполнено(ПользовательСсылка) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		ПользовательОбъект = ПользовательСсылка.ПолучитьОбъект();
		Для Каждого Контакт Из ПользовательОбъект.КонтактнаяИнформация Цикл
			Если Контакт.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты
				И НЕ ПустаяСтрока(Контакт.Представление) Тогда
				Возврат Контакт.Представление;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Возврат "";
	
КонецФункции // ПолучитьАдресПочтыПользователя()

// ────────────────────────────────────────────────
// Вспомогательные функции
// ────────────────────────────────────────────────

&НаСервере
Функция ОпределитьИмяАдминистратора()
	
	ТекПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();
	
	ТекПользователь = Справочники.Пользователи.НайтиПоРеквизиту(
		"ИдентификаторПользователяИБ", ТекПользовательИБ.УникальныйИдентификатор);
	
	Если ЗначениеЗаполнено(ТекПользователь) Тогда
		Возврат Строка(ТекПользователь);
	Иначе
		Возврат ТекПользовательИБ.Имя;
	КонецЕсли;
	
КонецФункции // ОпределитьИмяАдминистратора()

&НаСервере
Функция ОчиститьФИООтПостфиксов(ФИО)
	
	ФИООчищенное = СокрЛП(ФИО);
	Если Прав(ФИООчищенное, 1) = "," Тогда
		ФИООчищенное = СокрЛП(Лев(ФИООчищенное, СтрДлина(ФИООчищенное) - 1));
	КонецЕсли;
	
	МассивСлов = СтрРазделить(ФИООчищенное, " ", Ложь);
	
	Пока МассивСлов.Количество() > 2 Цикл
		ПоследнееСлово = МассивСлов[МассивСлов.Количество() - 1];
		Если ЭтоПостфикс(ПоследнееСлово) Тогда
			МассивСлов.Удалить(МассивСлов.Количество() - 1);
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(МассивСлов, " ");
	
КонецФункции // ОчиститьФИООтПостфиксов()

&НаСервере
Функция ЭтоПостфикс(Слово)
	
	Если СтрДлина(Слово) < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДопустимыеСимволы = "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
	
	Для НомерСимвола = 1 По СтрДлина(Слово) Цикл
		Если Найти(ДопустимыеСимволы, Сред(Слово, НомерСимвола, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции // ЭтоПостфикс()

&НаСервере
Функция ИзвлечьЗначениеПоля(Строка, ИмяПоля)
	
	Если НЕ СтрНачинаетсяС(Строка, ИмяПоля) Тогда
		Возврат "";
	КонецЕсли;
	
	Значение = СокрЛП(Сред(Строка, СтрДлина(ИмяПоля) + 1));
	Если Прав(Значение, 1) = "," Тогда
		Значение = СокрЛП(Лев(Значение, СтрДлина(Значение) - 1));
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции // ИзвлечьЗначениеПоля()

&НаСервере
Функция РазобратьДатуИзФайла(СтрокаДаты)
	
	СтрокаДаты = СокрЛП(СтрокаДаты);
	Если ПустаяСтрока(СтрокаДаты) Тогда
		Возврат '00010101';
	КонецЕсли;
	
	Части = СтрРазделить(СтрокаДаты, "-", Ложь);
	Если Части.Количество() <> 3 Тогда
		Возврат '00010101';
	КонецЕсли;
	
	Попытка
		Возврат Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
	Исключение
		Возврат '00010101';
	КонецПопытки;
	
КонецФункции // РазобратьДатуИзФайла()

&НаСервере
Процедура ДобавитьСтрокуВЛог(СтрокиЛога, СтрокаСотр, ЦветФона, ОписаниеСтатуса)
	
	ДатаУвольн = ?(СтрокаСотр.ДатаУвольнения = '00010101', "",
		Формат(СтрокаСотр.ДатаУвольнения, "ДФ=dd.MM.yyyy"));
	
	ПользПредст = ?(ЗначениеЗаполнено(СтрокаСотр.Пользователь),
		Строка(СтрокаСотр.Пользователь), "—");
	
	ОргПредст = ?(ЗначениеЗаполнено(СтрокаСотр.ОрганизацияВБазе),
		Строка(СтрокаСотр.ОрганизацияВБазе), СтрокаСотр.Организация);
	
	// Организация перевода: сначала ссылка из базы, потом строка из файла, потом пусто
	Если ЗначениеЗаполнено(СтрокаСотр.ОрганизацияПослеПеревода) Тогда
		ОргПереводаПредст = Строка(СтрокаСотр.ОрганизацияПослеПеревода);
	ИначеЕсли НЕ ПустаяСтрока(СтрокаСотр.ДругиеМестаРаботы) Тогда
		ОргПереводаПредст = СтрокаСотр.ДругиеМестаРаботы;
	Иначе
		ОргПереводаПредст = "";
	КонецЕсли;
	
	СтрокиЛога.Добавить(
		"<tr style='background:" + ЦветФона + ";'>"
		+ "<td>" + СтрокаСотр.ФИОИзФайла          + "</td>"
		+ "<td>" + ПользПредст                     + "</td>"
		+ "<td>" + ОргПредст                       + "</td>"
		+ "<td>" + СтрокаСотр.Должность            + "</td>"
		+ "<td align='center'>" + ДатаУвольн       + "</td>"
		+ "<td>" + СтрокаСотр.СписокВиз            + "</td>"
		+ "<td>" + СтрокаСотр.СписокРолей          + "</td>"
		+ "<td align='center'>" + ?(СтрокаСотр.ПометкаПеревода, "✓", "") + "</td>"
		+ "<td>" + ОргПереводаПредст               + "</td>"
		+ "<td>" + ОписаниеСтатуса                 + "</td>"
		+ "</tr>"
	);
	
КонецПроцедуры // ДобавитьСтрокуВЛог()

#КонецОбласти // СлужебныеСерверныеПроцедуры
